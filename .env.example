#PORT_SETTINGS
PORT=3000

# AGENT ENGINE CONFIGURATION
# Set to 'local' for offline desktop models (Ollama) / Android (LiteRT)
# Set to 'groq' for cloud-hosted high-speed processing
AI_MODE=local

# --- CLOUD CONFIGURATION (If AI_MODE=groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it

# --- LOCAL CONFIGURATION (If AI_MODE=local) ---
# Example for LiteRT (Android/Termux): http://127.0.0.1:8080/v1/chat/completions
# Example for Ollama (PC/Desktop): http://127.0.0.1:11434/v1/chat/completions
LOCAL_API_URL=http://127.0.0.1:8080/v1/chat/completions
LOCAL_MODEL=gemma-4-e2b-it

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@xyz.com
SMTP_PASS=your_16_digit_app_password
SMTP_FROM="Rashboard" <youremail@gmail.com>
